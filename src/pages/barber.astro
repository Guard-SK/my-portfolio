---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Image } from 'astro:assets'
import barberDemo from '../assets/barber_demo.avif'
---

<BaseLayout
    title="Web pre Barbershopy"
    description="Digitálne vizitky, ktoré nahradia lacný Linktree."
>
    <!-- HERO SECTION -->
    <section class="relative pb-12 lg:pt-12 px-6 overflow-hidden bg-obsidian">
        <!-- Maintained original background placement with added premium vibe -->
        <div
            class="absolute top-0 right-0 w-1/2 h-full bg-linear-to-bl from-emerald-900/30 to-slate-900/60 -z-10 -skew-x-12 translate-x-1/4 backdrop-blur-3xl border-l border-emerald-500/20 shadow-[-20px_0_60px_rgba(0,0,0,0.5)]"
        >
        </div>
        <div
            class="absolute top-1/4 right-[20%] w-[400px] h-[400px] bg-emerald-500/10 blur-[120px] rounded-full pointer-events-none -z-10"
        >
        </div>
        <div
            class="absolute inset-0 bg-grain opacity-40 pointer-events-none -z-10"
        >
        </div>

        <div
            class="max-w-7xl mx-auto flex flex-col items-center text-center fade-in-up"
        >
            <div
                class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-emerald-500/30 bg-emerald-500/10 mb-8 shadow-lg"
            >
                <span
                    class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"
                ></span>
                <span
                    class="text-[10px] uppercase font-bold tracking-widest text-emerald-400"
                    >Prémiové weby pre Barbershopy a Salóny</span
                >
            </div>

            <h1
                class="text-5xl md:text-7xl lg:text-8xl font-extrabold mb-8 tracking-tighter text-pearl"
            >
                Vy sa sústreďte na <br class="hidden sm:block" />
                <span class="text-emerald-400 italic font-black"
                    >dokonalý strih.</span
                >
            </h1>
            <h2
                class="text-3xl md:text-4xl font-bold text-pearl/90 mb-8 max-w-3xl"
            >
                Váš nový web sa postará o klientov.
            </h2>

            <p
                class="text-silver/90 text-lg md:text-xl mb-12 leading-relaxed max-w-3xl font-medium"
            >
                Prémiová digitálna vizitka, ktorá premení sledovateľov na
                klientov v kresle. Bleskový dizajn, okamžitá úprava cenníka a
                prepojenie na rezervácie bez skrytých provízií.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 mb-20 w-full sm:w-auto">
                <a
                    href="https://barbershop-demo-1.vercel.app"
                    target="_blank"
                    class="btn-primary text-lg bg-emerald-500! text-obsidian! hover:bg-emerald-400! px-8 py-4 shadow-[0_0_30px_rgba(16,185,129,0.3)]"
                >
                    Pozrieť Demo Barbershop
                </a>
                <a
                    href="#cennik"
                    class="btn-secondary text-lg px-8 py-4 bg-charcoal/40 backdrop-blur-md hover:bg-white/5 border-white/10 text-pearl"
                >
                    Cenník služieb
                </a>
            </div>
        </div>

        <!-- Demo Section (Maintained Layout) -->
        <div class="max-w-6xl mx-auto px-6 relative z-10">
            <div class="relative group">
                <a
                    href="https://barbershop-demo-1.vercel.app"
                    target="_blank"
                    class="block aspect-16/10 bg-slate-900 rounded-4xl overflow-hidden border border-white/10 shadow-[0_20px_80px_rgba(0,0,0,0.6)] relative ring-1 ring-white/5 hover:ring-emerald-500/40 transition-all duration-500"
                >
                    <div
                        class="absolute inset-0 bg-gradient-to-tr from-obsidian/80 via-transparent to-emerald-500/10 z-10"
                    >
                    </div>
                    <div
                        class="absolute inset-0 flex items-center justify-center bg-obsidian/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-20 backdrop-blur-sm"
                    >
                        <span
                            class="bg-emerald-500 text-obsidian px-6 py-3 rounded-full font-bold shadow-xl translate-y-4 group-hover:translate-y-0 transition-transform duration-300"
                        >
                            Prejsť na Demo <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><line x1="5" y1="12" x2="19" y2="12"
                                ></line><polyline points="12 5 19 12 12 19"
                                ></polyline></svg
                            >
                        </span>
                    </div>
                    <Image
                        src={barberDemo}
                        alt="Barber Demo"
                        class="absolute inset-0 w-full h-full object-cover transition-all duration-1000 group-hover:scale-105 opacity-90 group-hover:opacity-100"
                    />

                    <!-- Floating Badge -->
                    <div
                        class="absolute top-8 right-8 z-30 bg-emerald-500 text-obsidian px-5 py-2 rounded-full text-xs font-extrabold uppercase tracking-widest shadow-[0_10px_30px_rgba(16,185,129,0.4)] flex items-center gap-2"
                    >
                        Online Booking
                    </div>
                </a>

                <!-- Decorative "Sharp" elements -->
                <div
                    class="absolute -top-12 -left-12 w-28 h-28 border-t-2 border-l-2 border-emerald-500/40 rounded-tl-3xl pointer-events-none drop-shadow-[0_0_15px_rgba(16,185,129,0.3)]"
                >
                </div>
                <div
                    class="absolute -bottom-12 -right-12 w-28 h-28 border-b-2 border-r-2 border-emerald-500/40 rounded-br-3xl pointer-events-none drop-shadow-[0_0_15px_rgba(16,185,129,0.3)]"
                >
                </div>
            </div>
        </div>
    </section>

    <!-- PROBLEM & SOLUTION GRID -->
    <section
        class="py-24 lg:py-32 px-5 sm:px-6 bg-charcoal border-y border-white/5 relative"
    >
        <div class="max-w-7xl mx-auto">
            <div
                class="text-center max-w-3xl mx-auto mb-16 lg:mb-24 fade-in-up"
            >
                <h2
                    class="text-3xl md:text-5xl font-extrabold text-pearl leading-tight"
                >
                    Čo kazí váš imidž a <span class="text-emerald-500 italic"
                        >brzdí váš čas?</span
                    >
                </h2>
            </div>

            <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
                <!-- Card 1 -->
                <div
                    class="glass-card p-8 bg-white/5 border-emerald-500/20 shadow-[0_4px_24px_rgba(0,0,0,0.6)] hover:border-emerald-500/40 hover:bg-white/10 transition-all duration-300 group fade-in-up"
                >
                    <div class="mb-6 pb-6 border-b border-white/10">
                        <div
                            class="text-rose-400 text-sm font-bold uppercase tracking-wider mb-2 flex items-center gap-2"
                        >
                            Problém
                        </div>
                        <p
                            class="text-silver/80 text-lg group-hover:text-silver transition-colors"
                        >
                            Telefón neustále zvoní presne vtedy, keď robíte
                            najťažší fade.
                        </p>
                    </div>
                    <div>
                        <div
                            class="text-emerald-400 text-sm font-bold uppercase tracking-wider mb-2 flex items-center gap-2"
                        >
                            Riešenie
                        </div>
                        <p class="text-pearl font-bold text-xl leading-snug">
                            100% online rezervácie. Zákazníci sa objednajú sami,
                            aj o polnoci.
                        </p>
                    </div>
                </div>

                <!-- Card 2 -->
                <div
                    class="glass-card p-8 bg-white/5 border-emerald-500/20 shadow-[0_4px_24px_rgba(0,0,0,0.6)] hover:border-emerald-500/40 hover:bg-white/10 transition-all duration-300 group fade-in-up"
                    style="transition-delay: 100ms;"
                >
                    <div class="mb-6 pb-6 border-b border-white/10">
                        <div
                            class="text-rose-400 text-sm font-bold uppercase tracking-wider mb-2 flex items-center gap-2"
                        >
                            Problém
                        </div>
                        <p
                            class="text-silver/80 text-lg group-hover:text-silver transition-colors"
                        >
                            Zákazníci zabúdajú na termíny a vy prichádzate o
                            peniaze.
                        </p>
                    </div>
                    <div>
                        <div
                            class="text-emerald-400 text-sm font-bold uppercase tracking-wider mb-2 flex items-center gap-2"
                        >
                            Riešenie
                        </div>
                        <p class="text-pearl font-bold text-xl leading-snug">
                            Systém im automaticky pošle SMS pripomienku 24 hodín
                            vopred.
                        </p>
                    </div>
                </div>

                <!-- Card 3 -->
                <div
                    class="glass-card p-8 bg-white/5 border-emerald-500/20 shadow-[0_4px_24px_rgba(0,0,0,0.6)] hover:border-emerald-500/40 hover:bg-white/10 transition-all duration-300 group fade-in-up"
                    style="transition-delay: 200ms;"
                >
                    <div class="mb-6 pb-6 border-b border-white/10">
                        <div
                            class="text-rose-400 text-sm font-bold uppercase tracking-wider mb-2 flex items-center gap-2"
                        >
                            Problém
                        </div>
                        <p
                            class="text-silver/80 text-lg group-hover:text-silver transition-colors"
                        >
                            Odkaz vo vašom IG bio vedie na neprehľadnú a lacno
                            vyzerajúcu stránku.
                        </p>
                    </div>
                    <div>
                        <div
                            class="text-emerald-400 text-sm font-bold uppercase tracking-wider mb-2 flex items-center gap-2"
                        >
                            Riešenie
                        </div>
                        <p class="text-pearl font-bold text-xl leading-snug">
                            Prémiový web na vlastnej doméne, ktorý okamžite
                            buduje dôveru a luxus.
                        </p>
                    </div>
                </div>

                <!-- Card 4 -->
                <div
                    class="glass-card p-8 bg-white/5 border-emerald-500/20 shadow-[0_4px_24px_rgba(0,0,0,0.6)] hover:border-emerald-500/40 hover:bg-white/10 transition-all duration-300 group fade-in-up"
                    style="transition-delay: 300ms;"
                >
                    <div class="mb-6 pb-6 border-b border-white/10">
                        <div
                            class="text-rose-400 text-sm font-bold uppercase tracking-wider mb-2 flex items-center gap-2"
                        >
                            Problém
                        </div>
                        <p
                            class="text-silver/80 text-lg group-hover:text-silver transition-colors"
                        >
                            Zmena ceny služby alebo pridanie nového barbera do
                            tímu je nočná mora.
                        </p>
                    </div>
                    <div>
                        <div
                            class="text-emerald-400 text-sm font-bold uppercase tracking-wider mb-2 flex items-center gap-2"
                        >
                            Riešenie
                        </div>
                        <p class="text-pearl font-bold text-xl leading-snug">
                            Jednoduchá aplikácia v mobile, kde si cenník a tím
                            upravíte za 10 sekúnd.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section id="cennik" class="pt-24 px-6 relative">
        <div class="max-w-7xl mx-auto">
            <div class="text-center max-w-3xl mx-auto mb-20 fade-in-up">
                <h2 class="text-4xl md:text-5xl font-extrabold text-pearl mb-6">
                    Investícia do vašej značky. <span
                        class="block text-emerald-500 italic mt-2"
                        >Bez zbytočných percent z tržieb.</span
                    >
                </h2>
            </div>

            <div class="grid lg:grid-cols-12 gap-8 items-stretch">
                <!-- Main Package -->
                <div class="lg:col-span-5 relative fade-in-up h-full">
                    <div
                        class="absolute -inset-1 bg-linear-to-r from-emerald-500/40 to-emerald-400/10 rounded-3xl blur-xl opacity-50"
                    >
                    </div>
                    <div
                        class="glass-card p-8 sm:p-10 border-emerald-500/30 relative bg-obsidian/80 backdrop-blur-xl h-full flex flex-col"
                    >
                        <div
                            class="inline-block px-3 py-1 bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 rounded-full text-xs font-bold uppercase tracking-wider mb-6 w-fit"
                        >
                            Základ každého barbera
                        </div>
                        <h3 class="text-3xl font-extrabold text-pearl mb-2">
                            Digitálna Vizitka
                        </h3>
                        <div
                            class="flex flex-wrap items-baseline gap-x-2 gap-y-1 mb-8"
                        >
                            <span
                                class="text-4xl font-extrabold text-emerald-400 whitespace-nowrap"
                                >200 €</span
                            >
                            <span class="text-xl text-emerald-400/70 font-bold"
                                >–</span
                            >
                            <span
                                class="text-4xl font-extrabold text-emerald-400 whitespace-nowrap"
                                >350 €</span
                            >
                            <span class="text-silver/60 text-sm ml-1"
                                >(25/75 pred po)</span
                            >
                        </div>

                        <ul class="space-y-5 mb-10 grow">
                            <li class="flex items-center gap-4">
                                <div
                                    class="w-6 h-6 rounded-full bg-emerald-500/20 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="14"
                                        height="14"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="3"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-emerald-400"
                                        ><polyline points="20 6 9 17 4 12"
                                        ></polyline></svg
                                    >
                                </div>
                                <span
                                    class="text-pearl font-medium text-lg leading-snug"
                                    >Kompletný prémiový web (Astro)</span
                                >
                            </li>
                            <li class="flex items-center gap-4">
                                <div
                                    class="w-6 h-6 rounded-full bg-emerald-500/20 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="14"
                                        height="14"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="3"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-emerald-400"
                                        ><polyline points="20 6 9 17 4 12"
                                        ></polyline></svg
                                    >
                                </div>
                                <span
                                    class="text-pearl font-medium text-lg leading-snug"
                                    >Redakčný systém (CMS) pre Cenník a Tím</span
                                >
                            </li>
                            <li class="flex items-center gap-4">
                                <div
                                    class="w-6 h-6 rounded-full bg-emerald-500/20 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="14"
                                        height="14"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="3"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-emerald-400"
                                        ><polyline points="20 6 9 17 4 12"
                                        ></polyline></svg
                                    >
                                </div>
                                <span
                                    class="text-pearl font-medium text-lg leading-snug"
                                    >Automatické prepojenie s vaším Instagram
                                    feedom</span
                                >
                            </li>
                            <li class="flex items-center gap-4">
                                <div
                                    class="w-6 h-6 rounded-full bg-emerald-500/20 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="14"
                                        height="14"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="3"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-emerald-400"
                                        ><polyline points="20 6 9 17 4 12"
                                        ></polyline></svg
                                    >
                                </div>
                                <span
                                    class="text-pearl font-medium text-lg leading-snug"
                                    >Viacjazyčnosť (napr. SK + EN)</span
                                >
                            </li>
                            <li class="flex items-center gap-4">
                                <div
                                    class="w-6 h-6 rounded-full bg-emerald-500/20 flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="14"
                                        height="14"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="3"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="text-emerald-400"
                                        ><polyline points="20 6 9 17 4 12"
                                        ></polyline></svg
                                    >
                                </div>
                                <span
                                    class="text-pearl font-medium text-lg leading-snug"
                                    >Základné lokálne SEO pre Google Mapy</span
                                >
                            </li>
                        </ul>

                        <button
                            data-trigger-wizard="true"
                            class="btn-primary w-full text-center py-4 text-lg"
                            >Mám záujem</button
                        >
                    </div>
                </div>

                <!-- Add-ons -->
                <div
                    class="lg:col-span-7 flex flex-col gap-6 fade-in-up h-full justify-center"
                    style="transition-delay: 200ms;"
                >
                    <!-- Add-on 1 -->
                    <div
                        class="glass-card p-6 sm:p-8 border-white/5 hover:border-emerald-500/30 transition-colors"
                    >
                        <div
                            class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-4"
                        >
                            <div>
                                <div class="flex items-center gap-3 mb-2">
                                    <div
                                        class="w-12 h-12 rounded-xl bg-slate-800/80 flex items-center justify-center text-pearl border border-white/10 shrink-0"
                                    >
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="24"
                                            height="24"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            ><rect
                                                x="3"
                                                y="4"
                                                width="18"
                                                height="18"
                                                rx="2"
                                                ry="2"></rect><line
                                                x1="16"
                                                y1="2"
                                                x2="16"
                                                y2="6"></line><line
                                                x1="8"
                                                y1="2"
                                                x2="8"
                                                y2="6"></line><line
                                                x1="3"
                                                y1="10"
                                                x2="21"
                                                y2="10"></line></svg
                                        >
                                    </div>
                                    <h4 class="text-2xl font-bold text-pearl">
                                        Integrácia Rezervácií
                                    </h4>
                                </div>
                            </div>
                            <div class="text-left sm:text-right">
                                <div
                                    class="text-2xl font-bold text-emerald-400"
                                >
                                    + 100 € až 150 €*
                                </div>
                            </div>
                        </div>
                        <p class="text-silver text-lg leading-relaxed sm:pl-15">
                            Profesionálne napojenie na systém Booqme pre váš
                            kalendár. Koniec zvoniacim telefónom.
                        </p>
                        <div
                            class="p-4 rounded-xl bg-red-500/5 border border-red-500/10 text-sm text-silver/80 italic font-medium mt-4 sm:ml-15"
                        >
                            *Za samotný systém platíte priamo poskytovateľovi
                            transparentných 16,90 € / mesiac. Žiadne 20%
                            provízie za nových klientov ako pri iných apkách.
                        </div>
                    </div>

                    <!-- Add-on 2 -->
                    <div
                        class="glass-card p-6 sm:p-8 border-white/5 hover:border-emerald-500/30 transition-colors"
                    >
                        <div
                            class="flex flex-col sm:flex-row sm:items-start justify-between gap-4 mb-4"
                        >
                            <div>
                                <div class="flex items-center gap-3 mb-2">
                                    <div
                                        class="w-12 h-12 rounded-xl bg-slate-800/80 flex items-center justify-center text-pearl border border-white/10 shrink-0"
                                    >
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="24"
                                            height="24"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            ><path
                                                d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"
                                            ></path><path d="M3 6h18"
                                            ></path><path
                                                d="M16 10a4 4 0 0 1-8 0"
                                            ></path></svg
                                        >
                                    </div>
                                    <h4 class="text-2xl font-bold text-pearl">
                                        E-shop na kozmetiku
                                    </h4>
                                </div>
                            </div>
                            <div class="text-left sm:text-right">
                                <div
                                    class="text-2xl font-bold text-emerald-400"
                                >
                                    + 200 € až 350 €
                                </div>
                            </div>
                        </div>
                        <p class="text-silver text-lg leading-relaxed sm:pl-15">
                            Predávajte svoje pomády, oleje a merch priamo na
                            webe. Jednoduchý košík s platbou online.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Maintenance Section -->
    <section
        class="pt-12 pb-32 px-6 bg-obsidian relative border-t border-white/5 overflow-hidden"
    >
        <div class="absolute inset-0 pointer-events-none">
            <div
                class="absolute inset-x-0 bottom-0 h-full bg-linear-to-t from-emerald-500/5 to-transparent"
            >
            </div>
        </div>

        <div
            class="max-w-3xl mx-auto text-center relative z-10 fade-in-up glass-card p-10 lg:p-14 border-emerald-500/20 bg-charcoal/50"
        >
            <h2 class="text-4xl md:text-5xl font-extrabold text-pearl mb-8">
                Bezstarostná prevádzka
            </h2>
            <p class="text-silver/90 text-xl leading-relaxed">
                Strihajte bez stresu z techniky. Za férových <strong
                    class="text-emerald-400 font-bold border-b-2 border-emerald-500/30"
                    >12€ mesačne</strong
                > sa postarám o super-rýchly hosting, technické aktualizácie a predĺženie
                vašej domény. Vy sa venujete klientom, techniku riešim ja.
            </p>
            <button
                data-trigger-wizard="true"
                class="btn-secondary text-lg px-8 py-4 bg-obsidian/50 shadow-xl mt-10"
            >
                Dohodnúť si bezplatný hovor
            </button>
        </div>
    </section>
</BaseLayout>
