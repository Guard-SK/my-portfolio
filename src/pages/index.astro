---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Image } from 'astro:assets'
import auroraDesktop from '../assets/aurora_desktop.avif'
import auroraMobile from '../assets/aurora_mobile.avif'
import auroraLogo from '../assets/LogoAuroraConstruction.webp'
import david from '../assets/david.avif'
import barberDemo from '../assets/barber_demo.avif'
import restaurantDemo from '../assets/restaurant_demo.avif'
import hemisfera from '../assets/hemisfera.avif'
import medirex from '../assets/medirex.avif'
import medirexLogo from '../assets/medirex_logo.png'
import hemisferaLogo from '../assets/hemisfera_logo.png'
import epcm from '../assets/epcm.avif'
import epcmLogo from '../assets/epcm_logo.jpg'
import gastroCard from '../assets/gastro_card.avif'
import barberCard from '../assets/barber_card.avif'
---

<BaseLayout title="Webdeveloper Bratislava">
	<!-- Morphing Sticky Experience -->
	<section class="relative bg-grain pb-12 lg:pt-12">
		<!-- Contained Background Effects -->
		<div class="absolute inset-0 overflow-hidden pointer-events-none">
			<!-- Animated Background Elements -->
			<div class="absolute inset-0 performance-mesh opacity-40"></div>

			<!-- Custom Gradient Glows -->
			<div
				class="absolute top-1/4 -left-20 w-96 h-96 bg-emerald-400/20 blur-[120px] rounded-full"
			>
			</div>
			<div
				class="absolute bottom-1/4 -right-20 w-[600px] h-[600px] bg-emerald-600/15 blur-[150px] rounded-full"
			>
			</div>
		</div>

		<div
			class="max-w-7xl mx-auto w-full grid lg:grid-cols-2 lg:gap-20 items-start relative px-5 sm:px-6"
		>
			<!-- Left Column: Sequential Content -->
			<div
				class="relative z-10 pb-6 lg:pb-20 space-y-16 lg:space-y-[35vh]"
			>
				<!-- Hero Part -->
				<div
					id="hero-trigger"
					class="min-h-0 lg:min-h-[70vh] flex flex-col justify-center items-center lg:items-start text-center lg:text-left py-16 lg:py-0 lg:pt-0 will-change-[opacity,transform]"
				>
					<!-- Avatar + Badge row -->
					<div class="flex items-center gap-3 mb-5 lg:mb-8">
						<!-- Avatar (mobile only) -->
						<div
							class="lg:hidden w-10 h-10 rounded-full overflow-hidden border-2 border-emerald-500/40 shrink-0"
						>
							<Image
								src={david}
								alt="Dávid"
								class="w-full h-full object-cover"
							/>
						</div>
						<div
							class="flex flex-col gap-1 items-center lg:items-start"
						>
							<div
								class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/5 w-fit"
							>
								<span
									class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"
								></span>
								<span
									class="text-[10px] uppercase font-bold tracking-widest text-emerald-400"
									>Prijímam nové projekty</span
								>
							</div>
							<p
								class="lg:hidden text-xs text-silver/60 font-medium pl-1"
							>
								Dávid Zliechovec
							</p>
						</div>
					</div>

					<h1
						class="text-[3.6rem] leading-[1.08] sm:text-6xl md:text-7xl lg:text-8xl font-extrabold mb-4 lg:mb-8 tracking-tight text-pearl"
					>
						Bleskové <span
							class="text-emerald-500 text-glow italic pr-2"
							>dizajnové</span
						><br />webstránky
					</h1>

					<!-- Short version on mobile, full on desktop -->
					<p
						class="lg:hidden text-silver text-sm mb-6 leading-relaxed font-medium max-w-xs"
					>
						Prémiové weby za zlomok ceny vel'kých agentúr - rýchlo,
						krásne, efektívne.
					</p>
					<p
						class="hidden lg:block text-silver text-lg md:text-xl mb-12 max-w-xl leading-relaxed font-medium"
					>
						Tvorím weby, ktoré sú nielen technologicky dokonalé, ale
						aj krásne. Prinášam vám prémiovú kvalitu za zlomok ceny
						veľkých agentúr a mením návštevníkov na vašich verných
						zákazníkov.
					</p>

					<div
						class="flex flex-row gap-3 mb-6 lg:mb-0 w-full max-w-xs lg:max-w-none mx-auto lg:mx-0"
					>
						<a
							data-trigger-wizard="true"
							class="btn-primary flex-1 text-center text-sm px-4!"
						>
							Konzultácia
						</a>
						<a
							href="#prace"
							class="btn-secondary flex-1 text-center text-sm px-4!"
							>Moja práca</a
						>
					</div>

					<!-- Mobile trust badges -->
					<div
						class="lg:hidden flex items-center justify-center gap-4"
					>
						<div class="flex items-center gap-1.5">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="13"
								height="13"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="text-emerald-400 shrink-0"
								><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"
								></polyline><polyline points="16 7 22 7 22 13"
								></polyline></svg
							>
							<span
								class="text-[10px] uppercase font-bold tracking-wider text-silver/60"
								>Top 3 Google</span
							>
						</div>
						<div class="w-px h-3 bg-white/10"></div>
						<div class="flex items-center gap-1.5">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="13"
								height="13"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="text-emerald-400 shrink-0"
								><circle cx="12" cy="12" r="10"
								></circle><polyline points="12 6 12 12 16 14"
								></polyline></svg
							>
							<span
								class="text-[10px] uppercase font-bold tracking-wider text-silver/60"
								>Rýchly web</span
							>
						</div>
						<div class="w-px h-3 bg-white/10"></div>
						<div class="flex items-center gap-1.5">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="13"
								height="13"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="text-emerald-400 shrink-0"
								><path
									d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"
								></path></svg
							>
							<span
								class="text-[10px] uppercase font-bold tracking-wider text-silver/60"
								>Krásny dizajn</span
							>
						</div>
					</div>

					<!-- Desktop stats (original) -->
					<div
						class="hidden lg:grid mt-16 grid-cols-2 sm:grid-cols-3 gap-6 lg:gap-8 opacity-60"
					>
						<div class="group">
							<div
								class="text-pearl font-bold text-xl mb-1 group-hover:text-emerald-400 transition-colors"
							>
								Premium
							</div>
							<div
								class="text-[10px] uppercase tracking-widest font-bold text-silver/60"
							>
								Vizuálna kvalita
							</div>
						</div>
						<div class="group">
							<div
								class="text-pearl font-bold text-xl mb-1 group-hover:text-emerald-400 transition-colors"
							>
								Bleskové
							</div>
							<div
								class="text-[10px] uppercase tracking-widest font-bold text-silver/60"
							>
								Rýchlosť načít.
							</div>
						</div>
						<div class="group hidden sm:block">
							<div
								class="text-pearl font-bold text-xl mb-1 group-hover:text-emerald-400 transition-colors"
							>
								Lacné
							</div>
							<div
								class="text-[10px] uppercase tracking-widest font-bold text-silver/60"
							>
								VS veľké agentúry
							</div>
						</div>
					</div>
				</div>

				<!-- Case Study Part -->
				<div
					id="case-study-trigger"
					class="min-h-0 lg:min-h-[70vh] flex flex-col justify-center lg:opacity-0 will-change-[opacity,transform]"
				>
					<span
						class="text-emerald-400 font-bold uppercase tracking-widest text-sm mb-4 block"
						>Prípadová Štúdia</span
					>
					<h2
						class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 lg:mb-8 leading-tight text-pearl"
					>
						Ako som pomohol stavebnej firme ovládnuť Google.
					</h2>
					<p class="text-silver text-lg mb-8 leading-relaxed">
						Pre firmu <strong class="text-pearl"
							>Aurora Construction</strong
						> som vybudoval technický základ, ktorý ich vystrelil na prvé
						miesta v Google na kľúčové slovo <span
							class="text-emerald-400 font-semibold"
							>"Hrubá stavba Bratislava"</span
						>.
					</p>

					<div class="grid grid-cols-2 gap-4 lg:gap-6 mb-6 lg:mb-8">
						<div class="glass-card p-6!">
							<div
								class="text-3xl font-extrabold text-emerald-400 mb-1"
							>
								0.9s
							</div>
							<div
								class="text-xs uppercase tracking-wider text-silver/90 font-bold"
							>
								Čas načítania
							</div>
						</div>
						<div class="glass-card p-6!">
							<div
								class="text-3xl font-extrabold text-emerald-400 mb-1"
							>
								100%
							</div>
							<div
								class="text-xs uppercase tracking-wider text-silver/90 font-bold"
							>
								Mobile Score
							</div>
						</div>
						<div class="glass-card p-6!">
							<div
								class="text-3xl font-extrabold text-emerald-400 mb-1"
							>
								Áno
							</div>
							<div
								class="text-xs uppercase tracking-wider text-silver/90 font-bold"
							>
								Získava dopyty
							</div>
						</div>
						<div class="glass-card p-6!">
							<div
								class="text-3xl font-extrabold text-emerald-400 mb-1"
							>
								Top 3
							</div>
							<div
								class="text-xs uppercase tracking-wider text-silver/90 font-bold"
							>
								Pozície v Google
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Right Column: Sticky Visuals -->
			<div
				class="sticky top-24 h-[calc(100vh-6rem)] hidden lg:flex items-center justify-center"
			>
				<div
					id="experience-visual"
					class="relative w-full max-w-xl mx-auto py-12 transition-transform duration-700 ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform"
				>
					<!-- Main Mockup Container -->
					<div
						id="hero-parallax"
						class="relative z-20 group"
						data-depth="0.1"
					>
						<div
							id="main-screen"
							class="w-full aspect-video bg-obsidian rounded-3xl overflow-hidden border border-white/30 shadow-[0_30px_60px_rgba(0,0,0,0.8)] relative transition-all duration-700"
						>
							<Image
								src={auroraDesktop}
								alt="Aurora Construction Project"
								class="w-full h-full object-cover opacity-90 transition-opacity duration-700"
							/>
							<div
								class="absolute inset-0 bg-gradient-to-tr from-obsidian/40 to-transparent"
							>
							</div>
						</div>

						<!-- Floating Badges (Fade out on Case Study) -->
						<div
							id="badge-growth"
							class="absolute -top-10 -left-10 glass-card p-4! border-emerald-500/30 shadow-2xl animate-float transition-all duration-500"
							style="animation-delay: 1s;"
							data-depth="0.2"
						>
							<div class="flex items-center gap-3">
								<div
									class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 border border-emerald-500/20"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="22"
										height="22"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2.5"
										stroke-linecap="round"
										stroke-linejoin="round"
										><polyline
											points="22 7 13.5 15.5 8.5 10.5 2 17"
										></polyline><polyline
											points="16 7 22 7 22 13"
										></polyline></svg
									>
								</div>
								<div
									class="text-[10px] uppercase font-bold text-silver tracking-wider"
								>
									Viac<br />zákazníkov
								</div>
							</div>
						</div>

						<div
							id="badge-ui"
							class="absolute -bottom-10 -right-10 glass-card p-4! border-emerald-500/30 shadow-2xl animate-float transition-all duration-500"
							style="animation-delay: 2.5s;"
							data-depth="0.15"
						>
							<div class="flex items-center gap-3">
								<div
									class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 border border-emerald-500/20"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="20"
										height="20"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2.5"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path
											d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"
										></path><path d="M5 3v4"></path><path
											d="M19 17v4"></path><path d="M3 5h4"
										></path><path d="M17 19h4"></path></svg
									>
								</div>
								<div
									class="text-[10px] uppercase font-bold text-silver tracking-wider"
								>
									Moderné<br />UI / UX
								</div>
							</div>
						</div>

						<div
							id="badge-premium"
							class="absolute -top-6 -right-6 glass-card p-4! border-white/10 shadow-2xl animate-float transition-all duration-500"
							style="animation-delay: 4s;"
							data-depth="0.1"
						>
							<div class="flex items-center gap-3">
								<div
									class="text-pearl font-bold text-xs tracking-tight uppercase opacity-80"
								>
									Prémiová stránka
								</div>
							</div>
						</div>

						<!-- Mobile Mockup (Slides in on Case Study) -->
						<div
							id="mobile-mockup"
							class="absolute -bottom-10 -left-12 w-56 aspect-1119/2048 bg-obsidian rounded-4xl p-3 border-4 border-white/20 shadow-2xl z-20 translate-x-10 opacity-0 pointer-events-none will-change-[opacity,transform]"
						>
							<div
								class="w-full h-full bg-charcoal rounded-3xl overflow-hidden"
							>
								<Image
									src={auroraMobile}
									alt="Aurora Construction Mobile"
									class="w-full h-full object-cover"
								/>
							</div>
						</div>

						<!-- Browser Controls (Show on Case Study) -->
						<div
							id="browser-dots"
							class="absolute top-4 left-4 flex gap-1.5 z-20 opacity-0 transition-opacity duration-500"
						>
							<div class="w-2 h-2 rounded-full bg-red-500/40">
							</div>
							<div class="w-2 h-2 rounded-full bg-yellow-500/40">
							</div>
							<div class="w-2 h-2 rounded-full bg-emerald-500/40">
							</div>
						</div>
					</div>

					<!-- Decorative Background Circles -->
					<div
						class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] border border-white/5 rounded-full pointer-events-none scale-90 opacity-20"
						data-depth="0.05"
					>
					</div>
				</div>
			</div>

			<!-- Mobile Visual Fallback (Visible only on small screens) -->
			<div class="lg:hidden relative mt-4 mb-4">
				<div
					class="w-full aspect-video bg-charcoal rounded-2xl overflow-hidden border border-white/5 shadow-2xl"
				>
					<Image
						src={auroraDesktop}
						alt="Aurora Desktop"
						class="w-full h-full object-cover"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- Portfolio Works -->
	<section
		id="prace"
		class="py-16 lg:py-32 px-5 sm:px-6 relative z-10 border-y border-white/5 bg-charcoal/20"
	>
		<div class="max-w-7xl mx-auto">
			<div
				class="flex flex-col md:flex-row justify-between items-start mb-10 lg:mb-16 gap-4 lg:gap-6"
			>
				<div class="fade-in-up">
					<span
						class="text-emerald-400 font-bold uppercase tracking-widest text-sm mb-4 block"
						>Portfólio</span
					>
					<h2
						class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight text-pearl tracking-tight"
					>
						Moje <span class="text-emerald-500 italic pr-2"
							>projekty</span
						>
					</h2>
				</div>
				<p
					class="text-silver text-base md:text-lg max-w-md fade-in-up"
					style="transition-delay: 100ms;"
				>
					Výber mojich prác od vývoja pre veľké spoločnosti v agentúre
					až po rýchle, prémiové weby pre lokálne biznisy.
				</p>
			</div>

			<div class="grid md:grid-cols-2 gap-8 lg:gap-12 items-stretch">
				<!-- Project 1: Aurora Construction -->
				<a
					href="https://www.auroraconstruction.sk"
					target="_blank"
					rel="noopener noreferrer"
					class="group block h-full fade-in-up"
					style="transition-delay: 200ms;"
				>
					<div
						class="glass-card p-5! md:p-6! border-white/5 transition-all duration-500 group-hover:border-emerald-500/30 group-hover:bg-white/5 relative overflow-hidden flex flex-col h-full"
					>
						<div
							class="w-full aspect-[4/3] rounded-2xl overflow-hidden bg-obsidian relative mb-6 md:mb-8 border border-white/5 shrink-0"
						>
							<Image
								src={auroraDesktop}
								alt="Aurora Construction"
								class="w-full h-full object-cover object-top opacity-90 transition-all duration-700 group-hover:scale-105 group-hover:opacity-100"
							/>
							<div
								class="absolute bottom-3 left-3 bg-obsidian/60 backdrop-blur-md rounded-full p-1 border border-white/10 shadow-2xl transition-transform duration-500 group-hover:-translate-y-1 flex items-center justify-center"
							>
								<div
									class="w-10 h-10 sm:w-12 sm:h-12 rounded-full overflow-hidden shrink-0 flex items-center justify-center p-1"
								>
									<Image
										src={auroraLogo}
										alt="Aurora Construction Logo"
										class="w-full h-full object-contain"
									/>
								</div>
							</div>
						</div>

						<div
							class="flex justify-between items-start px-2 relative z-10 flex-grow"
						>
							<div class="pr-4">
								<h3
									class="text-2xl font-extrabold text-pearl mb-1 group-hover:text-emerald-400 transition-colors tracking-tight"
								>
									Aurora Construction
								</h3>
								<p class="text-silver/80 text-sm font-medium">
									Webstránka pre stavebnú firmu
								</p>
							</div>
							<div
								class="w-12 h-12 shrink-0 rounded-full border border-white/10 flex items-center justify-center text-silver group-hover:bg-emerald-400 group-hover:border-emerald-400 group-hover:text-obsidian transition-all duration-300 overflow-hidden relative"
							>
								<svg
									class="absolute transition-transform duration-300 group-hover:translate-x-[200%] group-hover:-translate-y-[200%]"
									xmlns="http://www.w3.org/2000/svg"
									width="20"
									height="20"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									><line x1="7" y1="17" x2="17" y2="7"
									></line><polyline points="7 7 17 7 17 17"
									></polyline></svg
								>
								<svg
									class="absolute transition-transform duration-300 -translate-x-[200%] translate-y-[200%] group-hover:translate-x-0 group-hover:translate-y-0"
									xmlns="http://www.w3.org/2000/svg"
									width="20"
									height="20"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									><line x1="7" y1="17" x2="17" y2="7"
									></line><polyline points="7 7 17 7 17 17"
									></polyline></svg
								>
							</div>
						</div>
					</div>
				</a>

				<!-- Project 2: EPCM Engineers -->
				<a
					href="https://www.epcm-engineers.com"
					target="_blank"
					rel="noopener noreferrer"
					class="group block h-full fade-in-up"
					style="transition-delay: 300ms;"
				>
					<div
						class="glass-card p-5! md:p-6! border-white/5 transition-all duration-500 group-hover:border-emerald-500/30 group-hover:bg-white/5 relative overflow-hidden flex flex-col h-full"
					>
						<div
