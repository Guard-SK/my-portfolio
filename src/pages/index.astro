					<div
						class="absolute inset-0 bg-obsidian/70 z-10 transition-colors group-hover:bg-obsidian/40"
					>
					</div>
					<Image
						src={barberCard}
						class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
						alt="Barber"
					/>

					<div class="relative z-20">
						<h3
							class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold mb-4 text-pearl group-hover:text-emerald-400 transition-colors tracking-tight"
						>
							Barber
						</h3>
						<p
							class="text-silver/80 text-sm sm:text-base md:text-xl mb-8 font-medium min-h-[3rem] md:min-h-[4rem]"
						>
							Váš web by mal vyzerať rovnako dobre ako vaše
							strihy.
						</p>
						<span
							class="btn-primary py-2.5! px-6! text-sm md:text-base"
							>Preskúmať &rarr;</span
						>
					</div>
				</a>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	// Custom Scroll Morphing & Sequential Fading Logic
	const initMorph = () => {
		// Only run the sticky animation on desktop (lg breakpoint = 1024px)
		if (window.innerWidth < 1024) return
		const heroTrigger = document.getElementById('hero-trigger')
		const caseStudyTrigger = document.getElementById('case-study-trigger')
		const badgeUi = document.getElementById('badge-ui')
		const badgeGrowth = document.getElementById('badge-growth')
		const badgePremium = document.getElementById('badge-premium')
		const mobileMockup = document.getElementById('mobile-mockup')
		const mainScreen = document.getElementById('main-screen')
		const experienceVisual = document.getElementById('experience-visual')

		if (!heroTrigger || !caseStudyTrigger || !experienceVisual) return

		const handleScroll = () => {
			const scrollY = window.scrollY
			const sectionTop =
				experienceVisual.closest('section')?.offsetTop || 0
			const relativeScroll = scrollY - sectionTop

			// 1. Threshold-based Scaling (1.2 -> 1.0)
			// Stays big (1.2) until Case Study transition threshold (500)
			if (relativeScroll > 500) {
				experienceVisual.style.transform = 'scale(1.0)'
			} else {
				experienceVisual.style.transform = 'scale(1.2)'
			}

			// 2. Sequential Text Fading
			// Hero Fade
			const heroFadeStart = 100
			const heroFadeEnd = 300
			const heroOpacity =
				1 -
				Math.min(
					Math.max(
						(relativeScroll - heroFadeStart) /
							(heroFadeEnd - heroFadeStart),
						0,
					),
					1,
				)
			heroTrigger.style.opacity = heroOpacity.toString()
			heroTrigger.style.pointerEvents =
				heroOpacity < 0.1 ? 'none' : 'auto'

			if (badgeUi) badgeUi.style.opacity = heroOpacity.toString()
			if (badgeGrowth) badgeGrowth.style.opacity = heroOpacity.toString()
			if (badgePremium)
				badgePremium.style.opacity = heroOpacity.toString()

			// Case Study Fade
			const caseFadeStart = 500
			const caseFadeEnd = 800
			const caseOpacity = Math.min(
				Math.max(
					(relativeScroll - caseFadeStart) /
						(caseFadeEnd - caseFadeStart),
					0,
				),
				1,
			)
			caseStudyTrigger.style.opacity = caseOpacity.toString()
			caseStudyTrigger.style.pointerEvents =
				caseOpacity < 0.1 ? 'none' : 'auto'

			// Morph Visuals
			if (mobileMockup) {
				mobileMockup.style.opacity = caseOpacity.toString()
				// Slide: 10px -> 0px
				const slideX = 10 - caseOpacity * 10
				mobileMockup.style.transform = `translateX(${slideX}px)`
				mobileMockup.style.pointerEvents =
					caseOpacity < 0.1 ? 'none' : 'auto'
			}

			if (mainScreen) {
				const borderAlpha = 0.3 + caseOpacity * 0.2
				mainScreen.style.borderColor = `rgba(255, 255, 255, ${borderAlpha})`
				mainScreen.style.boxShadow = `0 20px 50px rgba(0,0,0,0.8)`
			}
		}

		window.addEventListener(
			'scroll',
			() => {
				requestAnimationFrame(handleScroll)
			},
			{ passive: true },
		)
		handleScroll()
	}

	// Mouse Parallax Logic
	const initParallax = () => {
		const hero = document.getElementById('hero-parallax')
		const layers = hero?.querySelectorAll('[data-depth]')

		document.addEventListener('mousemove', (e) => {
			if (!hero || !layers) return

			const x = (window.innerWidth / 2 - e.pageX) / 40
			const y = (window.innerHeight / 2 - e.pageY) / 40

			layers.forEach((layer) => {
				const depth = parseFloat(
					layer.getAttribute('data-depth') || '0',
				)
				const moveX = x * depth
				const moveY = y * depth
				// Combine parallax with sticky transform if needed,
				// but here we just need a sub-wrapper to not fight with scaling
				const visual = layer as HTMLElement
				visual.style.transform = `translate3d(${moveX}px, ${moveY}px, 0)`
			})
		})
	}

	// Smooth Scroll Logic
	const initSmoothScroll = () => {
		document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
			anchor.addEventListener('click', (e) => {
				e.preventDefault()
				const targetId = (
					e.currentTarget as HTMLAnchorElement
				).getAttribute('href')
				const target = document.querySelector(targetId || '')
				target?.scrollIntoView({ behavior: 'smooth' })
			})
		})
	}

	document.addEventListener('astro:page-load', () => {
		initMorph()
		initParallax()
		initSmoothScroll()
	})
</script>
